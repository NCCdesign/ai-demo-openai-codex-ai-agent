{
  "name": "ncc-ai-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @aic/server --filter @aic/web dev",
    "check": "pnpm -r --if-present typecheck && pnpm --filter @aic/core check && pnpm --filter @aic/runtime check && pnpm --filter @aic/server check",
    "build": "pnpm -r --if-present build"
  },
  "devDependencies": {
    "@types/node": "^24.0.7",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
